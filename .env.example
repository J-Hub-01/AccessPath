# Copy this file to .env and fill in your real key.
# Never commit .env — it is already in .gitignore.

# Get a free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- v2: Firebase (optional) ---
# Powers the live, cross-device Order queue and Help Request queue (see
# accesspath_v2_vision.md). These values are NOT secret — a Firebase web
# config is a public app identifier, not a credential; see SECURITY.md.
# If you leave these blank, AccessPath automatically falls back to a
# same-browser demo mode (see src/lib/storeLocalBackend.ts) so the app is
# still fully demoable with zero setup.
#
# Create a free project at https://console.firebase.google.com, enable
# Firestore, then copy the web app config values below. Remember to also
# deploy firestore.rules (see DEPLOY.md) before going live.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
